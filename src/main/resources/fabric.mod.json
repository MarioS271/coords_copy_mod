	"authors": [
		"MarioS271"
	],
	"contact": {
		"sources": "https://github.com/MarioS271/coords-copy-minecraft-mod"
	},
	"license": "license.marios271.net/closed-source",
	"icon": "assets/coords_copy/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.marios271.coords_copy.CoordsCopy"
		],
		"client": [
			"net.marios271.coords_copy.CoordsCopyClient"
		],
		"fabric-datagen": [
			"net.marios271.coords_copy.CoordsCopyDataGenerator"
		]
	},
	"mixins": [
		"coords_copy.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.15.0",
